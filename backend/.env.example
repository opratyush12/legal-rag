# ── Data paths ──────────────────────────────────────────────────────────────────
# Container defaults: /data/csv and /data/pdfs (mounted via docker-compose volumes)
# Override below for local dev on Windows/macOS:
# CSV_PATH=C:\path\to\supreme_court_clean_english.csv
# PDF_LOCAL_DIR=C:\path\to\processed_data
CSV_PATH=/data/csv/supreme_court_clean_english.csv

PDF_STORAGE_BACKEND=local
PDF_LOCAL_DIR=/data/pdfs

S3_BUCKET=
S3_PREFIX=pdfs/
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── Groq ────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=

# ── Server ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── Index ───────────────────────────────────────────────────────────────────────
INDEX_DIR=./index_store
MAX_INDEX_ROWS=34137
CHUNK_SIZE=12000
OVERLAP=200
MIN_CHUNK_CHARS=100

# ── Models ──────────────────────────────────────────────────────────────────────
EMBED_MODEL=BAAI/bge-small-en-v1.5
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
EMBED_BATCH_SIZE=64

# ── Search ──────────────────────────────────────────────────────────────────────
FAISS_RETRIEVE_K=200
CANDIDATE_PDFS=20
TOP_K=5
SEMANTIC_WEIGHT=0.65
BM25_WEIGHT=0.35
USE_BM25=true
RERANK_CHUNKS=4
CHUNK_COUNT_BOOST=0.15

# ── Query expansion ─────────────────────────────────────────────────────────────
USE_QUERY_EXPANSION=true
QUERY_EXPANSION_VARIANTS=3

# ── Groq ────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=1024
GROQ_FALLBACK_MODELS=["llama-3.1-8b-instant","gemma2-9b-it"]
GROQ_SUMMARY_MAX_TOKENS=350
GROQ_SUMMARY_TEMPERATURE=0.2
GROQ_CHAT_TEMPERATURE=0.3
GROQ_ASSISTANT_TEMPERATURE=0.4
CHAT_CONTEXT_MAX_CHARS=5500
SUMMARY_CONTEXT_MAX_CHARS=1800

# ── Upload / PDF ────────────────────────────────────────────────────────────────
MAX_PDF_MB=20
PREVIEW_MAX_CHARS=4000

# ── Confidence thresholds ───────────────────────────────────────────────────────
CONFIDENCE_HIGH_THRESHOLD=4.0
CONFIDENCE_MEDIUM_THRESHOLD=0.0

# ── TTS ─────────────────────────────────────────────────────────────────────────
TTS_VOICE=hi-IN-SwaraNeural

# ── CORS (empty default = no allowed origins; set for your environments) ────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
