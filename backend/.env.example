# ── Data paths ──────────────────────────────────────────────────────────────────
CSV_PATH=C:\Users\PratyushOjha\Documents\projectPractice\supream_court_data\supreme_court_clean_engilsh.csv

PDF_STORAGE_BACKEND=local
PDF_LOCAL_DIR=C:\Users\PratyushOjha\Documents\projectPractice\supream_court_data\processed_data

S3_BUCKET=
S3_PREFIX=pdfs/
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── Index ───────────────────────────────────────────────────────────────────────
INDEX_DIR=./index_store
MAX_INDEX_ROWS=34137
CHUNK_SIZE=12000
OVERLAP=200
MIN_CHUNK_CHARS=100

# ── Models ──────────────────────────────────────────────────────────────────────
EMBED_MODEL=BAAI/bge-small-en-v1.5
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
EMBED_BATCH_SIZE=64

# ── Search ──────────────────────────────────────────────────────────────────────
FAISS_RETRIEVE_K=200
CANDIDATE_PDFS=20
TOP_K=5
SEMANTIC_WEIGHT=0.65
BM25_WEIGHT=0.35
USE_BM25=true
RERANK_CHUNKS=4
CHUNK_COUNT_BOOST=0.15

# ── Query expansion ─────────────────────────────────────────────────────────────
USE_QUERY_EXPANSION=true
QUERY_EXPANSION_VARIANTS=3

# ── Groq ────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=1024

# ── TTS ─────────────────────────────────────────────────────────────────────────
TTS_VOICE=hi-IN-SwaraNeural

# ── CORS ────────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
